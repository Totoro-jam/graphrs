{
  "name": "@graphrs/react-flow",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "React Flow adapter for @graphrs — convert between React Flow and graphrs formats, run WASM-powered layouts",
  "keywords": [
    "graph",
    "react-flow",
    "xyflow",
    "layout",
    "visualization",
    "wasm"
  ],
  "author": "Totoro-jam <moqiuchen66@gmail.com>",
  "homepage": "https://github.com/Totoro-jam/graphrs#readme",
  "bugs": {
    "url": "https://github.com/Totoro-jam/graphrs/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Totoro-jam/graphrs",
    "directory": "packages/react-flow"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js"
    },
    "./use-graphrs-layout": {
      "types": "./dist/use-graphrs-layout.d.ts",
      "import": "./dist/use-graphrs-layout.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --reporter=default --passWithNoTests",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@graphrs/core": "workspace:^",
    "@graphrs/layout": "workspace:^",
    "@xyflow/react": ">=12.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@xyflow/react": "^12.11.0",
    "react": "^19.2.7"
  }
}
