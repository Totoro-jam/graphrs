{
  "name": "@graphrs/path",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Shortest path and traversal algorithms (Dijkstra, Bellman-Ford, BFS, DFS) for @graphrs",
  "keywords": ["graph", "shortest-path", "dijkstra", "bfs", "dfs"],
  "repository": { "type": "git", "url": "https://github.com/Totoro-jam/graphrs", "directory": "packages/path" },
  "sideEffects": false,
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./dijkstra": { "types": "./dist/dijkstra.d.ts", "import": "./dist/dijkstra.js" },
    "./bellman-ford": { "types": "./dist/bellman-ford.d.ts", "import": "./dist/bellman-ford.js" },
    "./bfs": { "types": "./dist/bfs.d.ts", "import": "./dist/bfs.js" },
    "./dfs": { "types": "./dist/dfs.d.ts", "import": "./dist/dfs.js" },
    "./all-pairs": { "types": "./dist/all-pairs.d.ts", "import": "./dist/all-pairs.js" }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=default",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": { "@graphrs/core": "workspace:^" }
}
